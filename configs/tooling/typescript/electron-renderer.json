{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ADJUTORIX TypeScript / Electron Renderer",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "rootDir": "../../..",
    "outDir": "../../../.tmp/tsc/electron-renderer",
    "tsBuildInfoFile": "../../../node_modules/.cache/tsc/electron-renderer.tsbuildinfo",
    "baseUrl": "../../..",
    "paths": {
      "@/*": ["./*"],
      "@configs/*": ["configs/*"],
      "@docs/*": ["docs/*"],
      "@packages/*": ["packages/*"],
      "@tests/*": ["tests/*"],
      "@app-renderer/*": ["packages/adjutorix-app/src/renderer/*"],
      "@app-shared/*": ["packages/adjutorix-app/src/shared/*"],
      "@app-types/*": ["packages/adjutorix-app/src/types/*"]
    },
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "inlineSources": true,
    "incremental": true,
    "composite": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noPropertyAccessFromIndexSignature": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": false,
    "skipLibCheck": false,
    "useDefineForClassFields": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "importsNotUsedAsValues": "remove",
    "preserveValueImports": false,
    "customConditions": ["browser", "renderer"],
    "moduleSuffixes": ["", ".renderer", ".browser"],
    "plugins": []
  },
  "include": [
    "../../../packages/adjutorix-app/src/renderer/**/*.ts",
    "../../../packages/adjutorix-app/src/renderer/**/*.tsx",
    "../../../packages/adjutorix-app/src/shared/**/*.ts",
    "../../../packages/adjutorix-app/src/shared/**/*.tsx",
    "../../../packages/adjutorix-app/src/types/**/*.ts",
    "../../../packages/adjutorix-app/tests/renderer/**/*.ts",
    "../../../packages/adjutorix-app/tests/renderer/**/*.tsx",
    "../../../packages/adjutorix-app/tests/smoke/**/*.ts",
    "../../../packages/adjutorix-app/tests/smoke/**/*.tsx"
  ],
  "exclude": [
    "../../../packages/adjutorix-app/src/main/**",
    "../../../packages/adjutorix-app/src/preload/**",
    "../../../packages/adjutorix-app/tests/main/**",
    "../../../packages/adjutorix-cli/**",
    "../../../**/node_modules/**",
    "../../../**/dist/**",
    "../../../**/build/**",
    "../../../**/out/**",
    "../../../**/coverage/**",
    "../../../