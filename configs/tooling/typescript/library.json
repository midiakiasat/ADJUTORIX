{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ADJUTORIX TypeScript / Shared Library",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "types": [],
    "rootDir": "../../..",
    "outDir": "../../../.tmp/tsc/library",
    "tsBuildInfoFile": "../../../node_modules/.cache/tsc/library.tsbuildinfo",
    "baseUrl": "../../..",
    "paths": {
      "@/*": ["./*"],
      "@configs/*": ["configs/*"],
      "@docs/*": ["docs/*"],
      "@packages/*": ["packages/*"],
      "@tests/*": ["tests/*"],
      "@shared/*": ["packages/shared/*"],
      "@app-shared/*": ["packages/adjutorix-app/src/shared/*"]
    },
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "removeComments": false,
    "incremental": true,
    "composite": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noPropertyAccessFromIndexSignature": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": false,
    "skipLibCheck": false,
    "useDefineForClassFields": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "importsNotUsedAsValues": "remove",
    "preserveValueImports": false,
    "moduleSuffixes": ["", ".shared", ".lib"],
    "customConditions": ["library", "shared"],
    "plugins": []
  },
  "include": [
    "../../../packages/shared/**/*.ts",
    "../../../packages/shared/**/*.tsx",
    "../../../packages/adjutorix-app/src/shared/**/*.ts",
    "../../../packages/adjutorix-app/src/shared/**/*.tsx",
    "../../../tests/contracts/**/*.ts",
    "../../../tests/contracts/**/*.tsx"
  ],
  "exclude": [
    "../../../packages/adjutorix-app/src/main/**",
    "../../../packages/adjutorix-app/src/preload/**",
    "../../../packages/adjutorix-app/src/renderer/**",
    "../../../packages/adjutorix-app/tests/**",
    "../../../packages/adjutorix-cli/**",
    "../../../**/node_modules/**",
    "../../../**/dist/**",
    "../../../**/build/**",
    "../../../**/out/**",
    "../../../**/coverage/**",
    "../../../**/*.generated.ts",
    "../../../**/*.generated.tsx"
  ],
  "references": []
}
