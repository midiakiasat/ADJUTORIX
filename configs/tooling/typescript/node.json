{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ADJUTORIX TypeScript / Node Runtime",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "types": ["node"],
    "rootDir": "../../..",
    "outDir": "../../../.tmp/tsc/node-runtime",
    "tsBuildInfoFile": "../../../node_modules/.cache/tsc/node-runtime.tsbuildinfo",
    "baseUrl": "../../..",
    "paths": {
      "@/*": ["./*"],
      "@configs/*": ["configs/*"],
      "@docs/*": ["docs/*"],
      "@packages/*": ["packages/*"],
      "@tests/*": ["tests/*"],
      "@cli/*": ["packages/adjutorix-cli/*"],
      "@ci/*": ["configs/ci/*"],
      "@hooks/*": ["configs/hooks/*"],
      "@tooling/*": ["configs/tooling/*"]
    },
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "incremental": true,
    "composite": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noPropertyAccessFromIndexSignature": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": false,
    "skipLibCheck": false,
    "useDefineForClassFields": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "importsNotUsedAsValues": "remove",
    "preserveValueImports": false,
    "customConditions": ["node", "server", "cli"],
    "moduleSuffixes": ["", ".node", ".server", ".cli"],
    "plugins": []
  },
  "include": [
    "../../../configs/**/*.ts",
    "../../../packages/**/*.ts",
    "../../../tests/**/*.ts"
  ],
  "exclude": [
    "../../../packages/adjutorix-app/src/renderer/**",
    "../../../packages/adjutorix-app/tests/renderer/**",
    "../../../packages/adjutorix-app/tests/smoke/**",
    "../../../**/*.tsx",
    "../../../**/node_modules/**",
    "../../../**/dist/**",
    "../../../**/build/**",
    "../../../**/out/**",
    "../../../**/coverage/**",
    "../../../**/*.generated.ts"
  ],
  "references": []
}
