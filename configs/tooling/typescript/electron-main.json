{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ADJUTORIX TypeScript / Electron Main",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "types": ["node", "electron"],
    "rootDir": "../../..",
    "outDir": "../../../.tmp/tsc/electron-main",
    "tsBuildInfoFile": "../../../node_modules/.cache/tsc/electron-main.tsbuildinfo",
    "baseUrl": "../../..",
    "paths": {
      "@/*": ["./*"],
      "@configs/*": ["configs/*"],
      "@docs/*": ["docs/*"],
      "@packages/*": ["packages/*"],
      "@tests/*": ["tests/*"],
      "@app-main/*": ["packages/adjutorix-app/src/main/*"],
      "@app-preload/*": ["packages/adjutorix-app/src/preload/*"],
      "@app-shared/*": ["packages/adjutorix-app/src/shared/*"]
    },
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "incremental": true,
    "composite": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noPropertyAccessFromIndexSignature": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": false,
    "skipLibCheck": false,
    "useDefineForClassFields": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "importsNotUsedAsValues": "remove",
    "preserveValueImports": false,
    "moduleSuffixes": ["", ".main", ".electron"],
    "customConditions": ["electron", "main"],
    "plugins": []
  },
  "include": [
    "../../../packages/adjutorix-app/src/main/**/*.ts",
    "../../../packages/adjutorix-app/src/main/**/*.tsx",
    "../../../packages/adjutorix-app/src/preload/**/*.ts",
    "../../../packages/adjutorix-app/src/preload/**/*.tsx",
    "../../../packages/adjutorix-app/src/shared/**/*.ts",
    "../../../packages/adjutorix-app/src/shared/**/*.tsx",
    "../../../packages/adjutorix-app/tests/main/**/*.ts",
    "../../../packages/adjutorix-app/tests/main/**/*.tsx"
  ],
  "exclude": [
    "../../../packages/adjutorix-app/src/renderer/**",
    "../../../packages/adjutorix-app/tests/renderer/**",
    "../../../packages/adjutorix-app/tests/smoke/**",
    "../../../**/node_modules/**",
    "../../../**/dist/**",
    "../../../**/build/**",
    "../../../**/out/**",
    "../../../**/coverage/**",
    "../../../**/*.generated.ts",
    "../../../**/*.generated.tsx"
  ],
  "references": []
}
