# ADJUTORIX agent runtime environment example

#

# Purpose:

# - canonical example of supported environment variables for the governed agent

# - explicit separation between public network/runtime identity and private credentials/secrets

# - documents defaults, allowed values, and operational meaning without storing secrets

#

# Rules:

# - do NOT place plaintext secrets in this file

# - use OS keychain, CI secret injection, or untracked local env overrides for credentials

# - empty values mean "set only when needed", not "required plaintext here"

###############################################################################

# AGENT IDENTITY / MODE

###############################################################################

# Runtime mode selector.

# Allowed: development | test | production

ADJUTORIX_AGENT_MODE=development

# Human-readable agent name for logs, health endpoints, and audit surfaces.

ADJUTORIX_AGENT_NAME=adjutorix-agent

# Optional build/version identifier surfaced in health and status payloads.

ADJUTORIX_AGENT_VERSION=0.1.0-dev

# Optional instance identifier when multiple agents may run on the same host.

ADJUTORIX_AGENT_INSTANCE_ID=local-dev-1

###############################################################################

# NETWORK / RPC BINDING

###############################################################################

# Bind host for the governed RPC server.

ADJUTORIX_AGENT_HOST=127.0.0.1

# Bind port for the governed RPC server.

ADJUTORIX_AGENT_PORT=8000

# Public base URL advertised to local clients when needed.

ADJUTORIX_AGENT_PUBLIC_URL='[http://127.0.0.1:8000](http://127.0.0.1:8000)'

# Request body size ceiling in bytes.

ADJUTORIX_AGENT_MAX_REQUEST_BYTES=1048576

# Per-request execution timeout in milliseconds unless profile-specific policy overrides apply.

ADJUTORIX_AGENT_REQUEST_TIMEOUT_MS=30000

# Keepalive timeout in seconds for HTTP connections.

ADJUTORIX_AGENT_KEEPALIVE_TIMEOUT_S=10

###############################################################################

# AUTHENTICATION / TOKEN HANDLING

###############################################################################

# Optional explicit token file path. Leave unset to use the governed default path.

ADJUTORIX_TOKEN_FILE=

# Whether missing token should fail startup.

# Allowed: true | false

ADJUTORIX_REQUIRE_TOKEN=true

# Whether loopback-only local development may generate a token on first boot.

# Allowed: true | false

ADJUTORIX_ALLOW_BOOTSTRAP_TOKEN=true

# Optional keychain service label used to resolve protected credentials.

ADJUTORIX_KEYCHAIN_SERVICE=io.adjutorix.agent

###############################################################################

# WORKSPACE / STORAGE ROOTS

###############################################################################

# Optional default workspace root for tests or controlled local deployments.

ADJUTORIX_DEFAULT_WORKSPACE_ROOT=

# Root directory for ledger persistence.

ADJUTORIX_LEDGER_ROOT=.tmp/adjutorix/ledger

# Root directory for verify artifacts.

ADJUTORIX_VERIFY_ARTIFACT_ROOT=.tmp/adjutorix/verify

# Root directory for replay artifacts.

ADJUTORIX_REPLAY_ARTIFACT_ROOT=.tmp/adjutorix/replay

# Root directory for command audit artifacts.

ADJUTORIX_COMMAND_AUDIT_ROOT=.tmp/adjutorix/command-audit

# Root directory for transaction state persistence and crash resume metadata.

ADJUTORIX_TRANSACTION_STATE_ROOT=.tmp/adjutorix/transactions

###############################################################################

# VERIFY / REPLAY / GOVERNANCE

###############################################################################

# Freshness window for mutation-guard verify results in seconds.

ADJUTORIX_VERIFY_MAX_AGE_SECONDS=300

# Freshness window for release-guard verify results in seconds.

ADJUTORIX_RELEASE_VERIFY_MAX_AGE_SECONDS=900

# Whether replay must be deterministic for apply-capable transactions.

# Allowed: true | false

ADJUTORIX_REQUIRE_DETERMINISTIC_REPLAY=true

# Whether environment fingerprint mismatch should block mutation-guard operations.

# Allowed: true | false

ADJUTORIX_BLOCK_ON_ENVIRONMENT_DRIFT=true

# Whether policy binding mismatches should fail fast at startup.

# Allowed: true | false

ADJUTORIX_REQUIRE_POLICY_BINDINGS=true

###############################################################################

# SCHEDULER / EXECUTION LIMITS

###############################################################################

# Max concurrently running governed jobs.

ADJUTORIX_MAX_CONCURRENT_JOBS=4

# Max queued jobs awaiting execution.

ADJUTORIX_MAX_QUEUED_JOBS=128

# Poll interval for internal scheduler loops in milliseconds.

ADJUTORIX_SCHEDULER_POLL_INTERVAL_MS=250

# Heartbeat interval for running jobs in milliseconds.

ADJUTORIX_JOB_HEARTBEAT_INTERVAL_MS=1000

# Default hard timeout for long-running jobs in milliseconds.

ADJUTORIX_JOB_TIMEOUT_MS=1800000

# Whether crash-resume recovery is enabled.

# Allowed: true | false

ADJUTORIX_ENABLE_CRASH_RESUME=true

###############################################################################

# COMMAND / SUBPROCESS EXECUTION

###############################################################################

# Default shell executable used by governed command runner when a shell is explicitly required.

ADJUTORIX_DEFAULT_SHELL=/bin/zsh

# Maximum stdout/stderr bytes captured per command before truncation policies apply.

ADJUTORIX_COMMAND_MAX_CAPTURE_BYTES=1048576

# Default command timeout in milliseconds.

ADJUTORIX_COMMAND_TIMEOUT_MS=600000

# Whether raw shell wrappers should be rejected even in development.

# Allowed: true | false

ADJUTORIX_STRICT_COMMAND_POLICY=true

###############################################################################

# LOGGING / AUDIT / DIAGNOSTICS

###############################################################################

# Agent log level.

# Allowed: trace | debug | info | warn | error

ADJUTORIX_AGENT_LOG_LEVEL=info

# Directory for agent logs.

ADJUTORIX_AGENT_LOG_DIR=.tmp/adjutorix/agent-logs

# Whether structured JSON logs are enabled.

# Allowed: true | false

ADJUTORIX_AGENT_JSON_LOGS=false

# Whether governance decisions should be mirrored to local debug logs.

# Allowed: true | false

ADJUTORIX_LOCAL_GOVERNANCE_AUDIT=true

# Whether sensitive values must be aggressively redacted in stderr/stdout capture.

# Allowed: true | false

ADJUTORIX_REDACT_SENSITIVE_OUTPUT=true

###############################################################################

# HEALTH / OBSERVABILITY

###############################################################################

# Whether /health style status reporting is enabled.

# Allowed: true | false

ADJUTORIX_ENABLE_HEALTH_ENDPOINT=true

# Interval for internal self-health evaluation in milliseconds.

ADJUTORIX_HEALTH_EVALUATION_INTERVAL_MS=5000

# Whether runtime metrics collection is enabled.

# Allowed: true | false

ADJUTORIX_ENABLE_METRICS=false

###############################################################################

# SECRETS / EXTERNAL INTEGRATIONS

###############################################################################

# DO NOT store plaintext provider tokens in this file.

# Use keychain-backed or CI-injected secret resolution only.

# Whether keychain-backed secret lookup is enabled.

# Allowed: true | false

ADJUTORIX_ENABLE_KEYCHAIN=true

# Whether environment secret passthrough is disabled by default.

# Allowed: true | false

ADJUTORIX_FILTER_ENV_SECRETS=true

# Optional explicit allowlist of environment variable names that may be passed to child processes.

# Comma-separated; keep empty unless strictly required.

ADJUTORIX_CHILD_ENV_ALLOWLIST=

###############################################################################

# CI / TEST HARNESS OVERRIDES

###############################################################################

# Marks the agent as running under automated tests.

# Allowed: true | false

ADJUTORIX_UNDER_TEST=false

# Enables deterministic fixtures and controlled shortcuts for tests only.

# Allowed: true | false

ADJUTORIX_TEST_MODE=false

# Optional isolated temp root for integration or smoke tests.

ADJUTORIX_TEST_TMP_ROOT=

# Optional fixed workspace fixture root.

ADJUTORIX_TEST_WORKSPACE_ROOT=

# Optional flag to permit ephemeral in-memory ledger storage for tests.

# All
