# ADJUTORIX application runtime environment example

#

# Purpose:

# - canonical example of supported app runtime environment variables

# - explicit split between safe public renderer exposure and private main/preload/runtime values

# - document defaults, allowed values, and operational meaning without storing secrets

#

# Rules:

# - variables prefixed with VITE_ are renderer-exposed and therefore MUST be non-secret

# - secrets MUST NOT be placed in this file; use OS keychain, CI secret injection, or local untracked env files

# - empty values below indicate "set only when needed", not "plaintext required"

###############################################################################

# APPLICATION IDENTITY / CHANNEL

###############################################################################

# Human-readable release channel. Non-secret. Exposed to renderer.

# Allowed: dev | nightly | internal | beta | rc | stable | emergency

VITE_APP_CHANNEL=dev

# Application version string for UI display and diagnostics. Non-secret. Exposed to renderer.

VITE_APP_VERSION=0.1.0-dev

# Optional build identifier for support/debugging surfaces. Non-secret. Exposed to renderer.

VITE_APP_BUILD_ID=local-dev

# Runtime mode selector for main process and packaging-aware logic.

# Allowed: development | test | production

ADJUTORIX_RUNTIME_MODE=development

###############################################################################

# GOVERNED FEATURE FLAGS

###############################################################################

# Enables developer tools UI affordances. Non-secret. Exposed to renderer.

# Allowed: true | false

VITE_ENABLE_DEVTOOLS=true

# Enables mock runtime adapters for local development and UI test harnesses. Non-secret. Exposed to renderer.

# Allowed: true | false

VITE_ENABLE_MOCK_RUNTIME=false

# Enables strict governance banners and extra diagnostics in app chrome.

# Allowed: true | false

ADJUTORIX_ENABLE_GOVERNANCE_DEBUG=true

# Forces runtime to reject non-governed fallback paths even in development.

# Allowed: true | false

ADJUTORIX_STRICT_GOVERNANCE=true

# Enables verbose preload bridge tracing to main-process logs only.

# Allowed: true | false

ADJUTORIX_TRACE_PRELOAD_BRIDGE=false

###############################################################################

# WORKSPACE / SESSION RUNTIME

###############################################################################

# Default restore behavior when opening a previously known workspace.

# Allowed: disabled | safe_restore | trust_gated_restore | explicit_only

ADJUTORIX_SESSION_RESTORE_MODE=trust_gated_restore

# Max number of remembered workspaces in local session metadata.

ADJUTORIX_MAX_RECENT_WORKSPACES=20

# Soft threshold for very large workspace classification.

ADJUTORIX_LARGE_WORKSPACE_FILE_COUNT=200000

# Polling interval in ms when native file watching is unavailable.

ADJUTORIX_WATCH_POLL_INTERVAL_MS=1500

###############################################################################

# AGENT / RPC CONNECTIVITY

###############################################################################

# Local governed agent base URL.

ADJUTORIX_AGENT_URL=[http://127.0.0.1:8000](http://127.0.0.1:8000)

# Request timeout for RPC calls in milliseconds.

ADJUTORIX_RPC_TIMEOUT_MS=30000

# Maximum reconnect backoff for agent reconnect loops in milliseconds.

ADJUTORIX_RPC_MAX_RECONNECT_BACKOFF_MS=10000

# Health probe interval for agent connectivity in milliseconds.

ADJUTORIX_AGENT_HEALTH_INTERVAL_MS=5000

# Optional explicit token file path. Leave unset to use the default governed token location.

ADJUTORIX_TOKEN_FILE=

###############################################################################

# COMMAND / TERMINAL RUNTIME

###############################################################################

# Default shell executable for governed terminal sessions.

ADJUTORIX_DEFAULT_SHELL=/bin/zsh

# Max buffered terminal output retained in memory per session.

ADJUTORIX_TERMINAL_MAX_BUFFER_BYTES=1048576

# Hard timeout for governed command execution in milliseconds unless profile overrides apply.

ADJUTORIX_COMMAND_TIMEOUT_MS=600000

# Whether terminal transcripts should be persisted across app restarts.

# Allowed: true | false

ADJUTORIX_PERSIST_TERMINAL_TRANSCRIPTS=false

###############################################################################

# VERIFY / REPLAY / LEDGER

###############################################################################

# Freshness window for mutation-guard verification in seconds.

ADJUTORIX_VERIFY_MAX_AGE_SECONDS=300

# Freshness window for release-guard verification in seconds.

ADJUTORIX_RELEASE_VERIFY_MAX_AGE_SECONDS=900

# Enables extra replay integrity assertions in local/dev builds.

# Allowed: true | false

ADJUTORIX_REPLAY_STRICT_MODE=true

# Default selected ledger sequence strategy when opening a workspace.

# Allowed: head | last_safe | explicit_only

ADJUTORIX_LEDGER_SELECTION_MODE=head

###############################################################################

# LOGGING / AUDIT / DIAGNOSTICS

###############################################################################

# Main-process log level.

# Allowed: trace | debug | info | warn | error

ADJUTORIX_LOG_LEVEL=info

# Directory for local app logs and non-authoritative debug outputs.

ADJUTORIX_LOG_DIR=.tmp/adjutorix/logs

# Whether governance decisions should be mirrored to a local debug log sink.

# Allowed: true | false

ADJUTORIX_LOCAL_GOVERNANCE_AUDIT=true

# Whether crash reports are enabled. Secrets must still be redacted by policy.

# Allowed: true | false

ADJUTORIX_ENABLE_CRASH_REPORTING=false

###############################################################################

# PACKAGING / DISTRIBUTION AWARENESS

###############################################################################

# Declares whether the app is running as an unpackaged dev build.

# Allowed: true | false

ADJUTORIX_UNPACKAGED=true

# Optional explicit path to bundled CLI resources when running packaged builds.

ADJUTORIX_BUNDLED_CLI_DIR=

# Optional explicit path to packaged docs/resources.

ADJUTORIX_RESOURCE_DIR=

###############################################################################

# OS INTEGRATIONS

###############################################################################

# Whether local desktop notifications are enabled.

# Allowed: true | false

ADJUTORIX_ENABLE_NOTIFICATIONS=true

# Whether opening external links is allowed through governed wrappers.

# Allowed: true | false

ADJUTORIX_ALLOW_EXTERNAL_LINKS=true

###############################################################################

# SECRETS / CREDENTIALS

###############################################################################

# DO NOT place plaintext secrets in this example file.

# Use keychain-backed resolution or local untracked env overrides instead.

# Optional keychain service label used by the main process when resolving secrets.

ADJUTORIX_KEYCHAIN_SERVICE=io.adjutorix.desktop

# Optional environment toggle to disable keychain lookup in test harnesses.

# Allowed: true | false

ADJUTORIX_DISABLE_KEYCHAIN=false

###############################################################################

# CI / TEST HARNESS OVERRIDES

###############################################################################

# Marks the runtime as executing under automated harness conditions.

# Allowed: true | false

ADJUTORIX_UNDER_TEST=false

# Enables deterministic fixtures and disables selected interactive prompts.

# Allowed: true | false

ADJUTORIX_TEST_MODE=false

# Optional fixed user-data directory for hermetic smoke or integration tests.

ADJUTORIX_USER_DATA_DIR=

# Optional fixed workspace fixture root for local automation.

ADJUTORIX_TEST_WORKSPACE_ROOT=
