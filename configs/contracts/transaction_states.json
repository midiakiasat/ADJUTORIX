        "failed",
        "timed_out",
        "cancelled",
        "rolled_back"
      ],
      "requires_verify": true,
      "requires_replay": true,
      "requires_confirmation": true
    }
  },
  "transitions": [
    {
      "from": "created",
      "event": "admit",
      "to": "admitted",
      "guards": [
        "policy_bound",
        "target_identity_resolved"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "admitted",
      "event": "hydrate_context_ok",
      "to": "hydrating_context",
      "guards": [
        "policy_bound"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "hydrating_context",
      "event": "trust_denied",
      "to": "awaiting_trust",
      "guards": [
        "workspace_present"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_trust",
      "event": "trust_granted",
      "to": "awaiting_input",
      "guards": [
        "workspace_trusted"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "hydrating_context",
      "event": "input_bound",
      "to": "awaiting_input",
      "guards": [
        "target_identity_resolved"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_input",
      "event": "verify_started",
      "to": "awaiting_verify",
      "guards": [
        "workspace_present",
        "target_identity_resolved"
      ],
      "applies_to": [
        "patch_review",
        "patch_apply",
        "rollback",
        "command_run",
        "release_promotion"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_verify",
      "event": "verify_passed",
      "to": "awaiting_replay",
      "guards": [
        "verify_passed",
        "verify_fresh"
      ],
      "applies_to": [
        "patch_review",
        "patch_apply",
        "rollback",
        "release_promotion"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_verify",
      "event": "verify_passed",
      "to": "ready",
      "guards": [
        "verify_passed",
        "verify_fresh"
      ],
      "applies_to": [
        "command_run"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_verify",
      "event": "verify_warned",
      "to": "blocked",
      "guards": [],
      "applies_to": [
        "patch_apply",
        "rollback",
        "release_promotion"
      ],
      "recovery_mode": "force_failed"
    },
    {
      "from": "awaiting_verify",
      "event": "verify_failed",
      "to": "failed",
      "guards": [],
      "recovery_mode": "force_failed"
    },
    {
      "from": "awaiting_verify",
      "event": "verify_stale",
      "to": "blocked",
      "guards": [],
      "recovery_mode": "force_failed"
    },
    {
      "from": "awaiting_replay",
      "event": "replay_passed",
      "to": "awaiting_confirmation",
      "guards": [
        "replay_passed",
        "replay_deterministic",
        "environment_compatible"
      ],
      "applies_to": [
        "patch_apply",
        "rollback",
        "release_promotion"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_replay",
      "event": "replay_passed",
      "to": "ready",
      "guards": [
        "replay_passed",
        "replay_deterministic",
        "environment_compatible"
      ],
      "applies_to": [
        "verify_run",
        "replay_run",
        "patch_review"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_replay",
      "event": "replay_failed",
      "to": "failed",
      "guards": [],
      "recovery_mode": "force_failed"
    },
    {
      "from": "awaiting_replay",
      "event": "replay_non_deterministic",
      "to": "blocked",
      "guards": [],
      "recovery_mode": "force_failed"
    },
    {
      "from": "awaiting_confirmation",
      "event": "confirmation_received",
      "to": "ready",
      "guards": [
        "confirmation_present",
        "confirmation_fresh"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "awaiting_confirmation",
      "event": "confirmation_expired",
      "to": "blocked",
      "guards": [],
      "recovery_mode": "force_failed"
    },
    {
      "from": "ready",
      "event": "scheduler_admitted",
      "to": "scheduled",
      "guards": [
        "scheduler_admitted"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "scheduled",
      "event": "run_started",
      "to": "running",
      "guards": [],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "running",
      "event": "run_failed",
      "to": "failed",
      "guards": [],
      "recovery_mode": "force_failed"
    },
    {
      "from": "running",
      "event": "run_timed_out",
      "to": "timed_out",
      "guards": [],
      "recovery_mode": "force_failed"
    },
    {
      "from": "running",
      "event": "request_rollback",
