      ],
      "requires_verify": true,
      "requires_replay": true,
      "requires_confirmation": true
    },
    "command_run": {
      "initial_state": "created",
      "success_states": [
        "completed",
        "completed_with_warnings"
      ],
      "failure_states": [
        "denied",
        "blocked",
        "failed",
        "timed_out",
        "cancelled"
      ],
      "requires_verify": false,
      "requires_replay": false,
      "requires_confirmation": true
    },
    "settings_update": {
      "initial_state": "created",
      "success_states": [
        "completed"
      ],
      "failure_states": [
        "denied",
        "blocked",
        "failed",
        "timed_out",
        "cancelled"
      ],
      "requires_verify": false,
      "requires_replay": false,
      "requires_confirmation": true
    },
    "trust_update": {
      "initial_state": "created",
      "success_states": [
        "completed"
      ],
      "failure_states": [
        "denied",
        "blocked",
        "failed",
        "timed_out",
