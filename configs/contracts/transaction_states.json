{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "adjutorix.transaction-states",
  "version": 1,
  "title": "ADJUTORIX Transaction State Machine Contract",
  "description": "Canonical machine-readable contract for authoritative transaction states, phases, transitions, guards, recovery semantics, and terminal outcomes across ADJUTORIX jobs, patch flows, verification, apply, rollback, ledger recording, and crash resume.",
  "status": "active",
  "owners": [
    "core-governance",
    "runtime-orchestration",
    "replay-runtime",
    "verify-runtime"
  ],
  "defaults": {
    "unknown_state_behavior": "deny",
    "unknown_transition_behavior": "deny",
    "missing_guard_behavior": "deny"
  },
  "invariants": [
    "Every transaction has exactly one current authoritative state.",
    "Every state transition must be explicit, guarded, and auditable.",
    "No terminal state may transition except through an explicit recovery or rollback transaction defined here.",
    "No apply-like mutation may enter execution without trust, verify, replay, and confirmation guards where required.",
    "Crash recovery must resume from persisted state, never inferred memory-only intent."
  ],
  "enums": {
    "transaction_kind": [
      "workspace_open",
      "verify_run",
      "replay_run",
      "patch_review",
      "patch_apply",
      "rollback",
      "command_run",
      "settings_update",
      "trust_update",
      "release_promotion"
    ],
    "state_class": [
      "initial",
      "active",
      "waiting",
      "blocked",
      "terminal_success",
      "terminal_failure",
      "terminal_abort",
      "terminal_rollback",
      "recovery"
    ],
    "state": [
      "created",
      "admitted",
      "hydrating_context",
      "awaiting_trust",
      "awaiting_input",
      "awaiting_verify",
      "awaiting_replay",
      "awaiting_confirmation",
      "ready",
      "scheduled",
      "running",
      "persisting_artifacts",
      "persisting_ledger",
      "completed",
      "completed_with_warnings",
      "denied",
      "blocked",
      "failed",
      "timed_out",
      "cancelled",
      "rollback_pending",
      "rolled_back",
      "recovery_pending",
      "recovering",
      "superseded"
    ],
    "guard": [
      "workspace_present",
      "workspace_trusted",
      "workspace_healthy",
      "target_identity_resolved",
      "policy_bound",
      "verify_passed",
      "verify_fresh",
      "replay_passed",
      "replay_deterministic",
      "environment_compatible",
      "confirmation_present",
      "confirmation_fresh",
      "scheduler_admitted",
      "ledger_available",
      "rollback_target_available",
      "secrets_clean",
      "release_attested"
    ],
    "event": [
      "create",
      "admit",
      "hydrate_context_ok",
      "hydrate_context_failed",
      "trust_granted",
      "trust_denied",
      "input_bound",
      "verify_started",
      "verify_passed",
      "verify_warned",
      "verify_failed",
      "verify_stale",
      "replay_started",
      "replay_passed",
      "replay_failed",
      "replay_non_deterministic",
      "confirmation_received",
      "confirmation_expired",
      "scheduler_admitted",
      "run_started",
      "run_progressed",
      "run_failed",
      "run_timed_out",
      "artifacts_persisted",
      "ledger_persisted",
      "complete_ok",
      "complete_warn",
      "deny",
      "block",
      "cancel",
      "supersede",
      "request_rollback",
      "rollback_completed",
      "crash_detected",
      "resume",
      "recovery_failed"
    ],
    "persistence_requirement": [
      "none",
      "context_only",
      "artifacts_required",
      "ledger_required",
      "artifacts_and_ledger_required"
    ],
    "recovery_mode": [
      "none",
      "resume_same_state",
      "resume_next_safe_state",
      "force_failed",
      "force_rollback"
    ],
    "decision": [
      "allow",
      "allow_with_warning",
      "deny"
    ]
  },
  "shared": {
    "required_transaction_fields": [
      "transaction_id",
      "transaction_kind",
      "state",
      "state_class",
      "created_at",
      "updated_at",
      "authority_surface"
    ],
    "required_audit_fields": [
      "transaction_id",
      "transaction_kind",
      "from_state",
      "to_state",
      "event",
      "evaluated_at"
    ]
  },
  "state_definitions": {
    "created": {
      "class": "initial",
      "description": "Transaction intent exists but has not yet been admitted by authoritative runtime policy.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "admitted": {
      "class": "active",
      "description": "Transaction passed initial admission checks and is now authoritative for further evaluation.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "hydrating_context": {
      "class": "active",
      "description": "Runtime is resolving workspace, target, policy, and environment context needed for guards.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "awaiting_trust": {
      "class": "waiting",
      "description": "Transaction is blocked on trust state being elevated or revalidated.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": [
        "workspace_open",
        "verify_run",
        "replay_run",
        "patch_review",
        "patch_apply",
        "rollback",
        "command_run",
        "settings_update",
        "trust_update",
        "release_promotion"
      ]
    },
    "awaiting_input": {
      "class": "waiting",
      "description": "Transaction requires additional explicit scope, target, or policy-bound input before continuing.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "awaiting_verify": {
      "class": "waiting",
      "description": "Transaction requires fresh authoritative verification before execution may continue.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": [
        "patch_review",
        "patch_apply",
        "rollback",
        "command_run",
        "release_promotion"
      ]
    },
    "awaiting_replay": {
      "class": "waiting",
      "description": "Transaction requires replay/lineage evidence before execution may continue.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": [
        "verify_run",
        "patch_review",
        "patch_apply",
        "rollback",
        "release_promotion"
      ]
    },
    "awaiting_confirmation": {
      "class": "waiting",
      "description": "Transaction is ready in principle but requires explicit fresh confirmation to proceed.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": [
        "patch_apply",
        "rollback",
        "command_run",
        "settings_update",
        "trust_update",
        "release_promotion"
      ]
    },
    "ready": {
      "class": "active",
      "description": "All required guards are satisfied and the transaction may be scheduled or executed.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "scheduled": {
      "class": "active",
      "description": "Transaction has been admitted to the governed scheduler and is queued for execution.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "running": {
      "class": "active",
      "description": "Consequential execution is in progress under authoritative tracking.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "persisting_artifacts": {
      "class": "active",
      "description": "Execution completed sufficiently to persist generated evidence or artifacts.",
      "terminal": false,
      "requires_persistence": "artifacts_required",
      "allowed_kinds": "all"
    },
    "persisting_ledger": {
      "class": "active",
      "description": "Execution and artifact persistence completed sufficiently to record authoritative ledger edges.",
      "terminal": false,
      "requires_persistence": "ledger_required",
      "allowed_kinds": [
        "verify_run",
        "replay_run",
        "patch_apply",
        "rollback",
        "command_run",
        "release_promotion"
      ]
    },
    "completed": {
      "class": "terminal_success",
      "description": "Transaction reached successful terminal completion with all required persistence satisfied.",
      "terminal": true,
      "requires_persistence": "artifacts_and_ledger_required",
      "allowed_kinds": "all"
    },
    "completed_with_warnings": {
      "class": "terminal_success",
      "description": "Transaction completed successfully but with non-blocking warnings captured in authoritative evidence.",
      "terminal": true,
      "requires_persistence": "artifacts_and_ledger_required",
      "allowed_kinds": "all"
    },
    "denied": {
      "class": "terminal_abort",
      "description": "Transaction was explicitly denied by policy, trust, or authority rules before execution completed.",
      "terminal": true,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "blocked": {
      "class": "terminal_failure",
      "description": "Transaction became non-progressable because a required guard or dependency failed irrecoverably.",
      "terminal": true,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "failed": {
      "class": "terminal_failure",
      "description": "Transaction execution failed after admission or scheduling.",
      "terminal": true,
      "requires_persistence": "artifacts_required",
      "allowed_kinds": "all"
    },
    "timed_out": {
      "class": "terminal_failure",
      "description": "Transaction exceeded its allowed execution or waiting deadline.",
      "terminal": true,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "cancelled": {
      "class": "terminal_abort",
      "description": "Transaction was explicitly cancelled before successful completion.",
      "terminal": true,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "rollback_pending": {
      "class": "blocked",
      "description": "A failure or explicit request requires rollback to a previously attested target.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": [
        "patch_apply",
        "rollback",
        "release_promotion"
      ]
    },
    "rolled_back": {
      "class": "terminal_rollback",
      "description": "Transaction ended by completing an authoritative rollback path.",
      "terminal": true,
      "requires_persistence": "artifacts_and_ledger_required",
      "allowed_kinds": [
        "patch_apply",
        "rollback",
        "release_promotion"
      ]
    },
    "recovery_pending": {
      "class": "recovery",
      "description": "Crash or interruption was detected and persisted state requires recovery evaluation.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "recovering": {
      "class": "recovery",
      "description": "Runtime is reconstructing authoritative state from persisted evidence to resume or fail safely.",
      "terminal": false,
      "requires_persistence": "context_only",
      "allowed_kinds": "all"
    },
    "superseded": {
      "class": "terminal_abort",
      "description": "Transaction is no longer authoritative because a newer transaction with the same scope superseded it.",
      "terminal": true,
      "requires_persistence": "context_only",
      "allowed_kinds": [
        "verify_run",
        "replay_run",
        "patch_review",
        "release_promotion"
      ]
    }
  },
  "kind_profiles": {
    "workspace_open": {
      "initial_state": "created",
      "success_states": [
        "completed",
        "completed_with_warnings"
      ],
      "failure_states": [
        "denied",
        "blocked",
        "failed",
        "timed_out",
        "cancelled"
      ],
      "requires_verify": false,
      "requires_replay": false,
      "requires_confirmation": false
    },
    "verify_run": {
      "initial_state": "created",
      "success_states": [
        "completed",
        "completed_with_warnings"
      ],
      "failure_states": [
        "denied",
        "blocked",
        "failed",
        "timed_out",
