        "patch_apply",
        "rollback",
        "release_promotion"
      ],
      "recovery_mode": "force_rollback"
    },
    {
      "from": "running",
      "event": "artifacts_persisted",
      "to": "persisting_artifacts",
      "guards": [],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "persisting_artifacts",
      "event": "ledger_persisted",
      "to": "persisting_ledger",
      "guards": [
        "ledger_available"
      ],
      "applies_to": [
        "verify_run",
        "replay_run",
        "patch_apply",
        "rollback",
        "command_run",
        "release_promotion"
      ],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "persisting_artifacts",
      "event": "complete_ok",
      "to": "completed",
      "guards": [],
      "applies_to": [
        "workspace_open",
        "patch_review",
        "settings_update",
        "trust_update"
      ],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "persisting_ledger",
      "event": "complete_ok",
      "to": "completed",
      "guards": [],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "persisting_ledger",
      "event": "complete_warn",
      "to": "completed_with_warnings",
      "guards": [],
      "applies_to": [
        "verify_run",
        "replay_run",
        "patch_review",
        "command_run"
      ],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "rollback_pending",
      "event": "rollback_completed",
      "to": "rolled_back",
      "guards": [
        "rollback_target_available",
        "ledger_available"
      ],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "created",
      "event": "deny",
      "to": "denied",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "admitted",
      "event": "deny",
      "to": "denied",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "hydrating_context",
      "event": "deny",
      "to": "denied",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "created",
      "event": "block",
      "to": "blocked",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "admitted",
      "event": "block",
      "to": "blocked",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "ready",
      "event": "cancel",
      "to": "cancelled",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "scheduled",
      "event": "cancel",
      "to": "cancelled",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "running",
      "event": "cancel",
      "to": "cancelled",
      "guards": [],
      "recovery_mode": "none"
    },
    {
      "from": "completed",
      "event": "supersede",
      "to": "superseded",
      "guards": [],
      "applies_to": [
        "verify_run",
        "replay_run",
        "patch_review",
        "release_promotion"
      ],
      "recovery_mode": "none"
    },
    {
      "from": "completed_with_warnings",
      "event": "supersede",
      "to": "superseded",
      "guards": [],
      "applies_to": [
        "verify_run",
        "replay_run",
        "patch_review",
        "release_promotion"
      ],
      "recovery_mode": "none"
    },
    {
      "from": "scheduled",
      "event": "crash_detected",
      "to": "recovery_pending",
      "guards": [],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "running",
      "event": "crash_detected",
      "to": "recovery_pending",
      "guards": [],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "persisting_artifacts",
      "event": "crash_detected",
      "to": "recovery_pending",
      "guards": [],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "persisting_ledger",
      "event": "crash_detected",
      "to": "recovery_pending",
      "guards": [],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "recovery_pending",
      "event": "resume",
      "to": "recovering",
      "guards": [],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "recovering",
      "event": "resume",
      "to": "scheduled",
      "guards": [
        "scheduler_admitted"
      ],
      "when_previous_state_in": [
        "scheduled"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "recovering",
      "event": "resume",
      "to": "running",
      "guards": [],
      "when_previous_state_in": [
        "running"
      ],
      "recovery_mode": "resume_same_state"
    },
    {
      "from": "recovering",
      "event": "resume",
      "to": "persisting_artifacts",
      "guards": [],
      "when_previous_state_in": [
        "persisting_artifacts"
      ],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "recovering",
      "event": "resume",
      "to": "persisting_ledger",
      "guards": [
        "ledger_available"
      ],
      "when_previous_state_in": [
        "persisting_ledger"
      ],
      "recovery_mode": "resume_next_safe_state"
    },
    {
      "from": "recovering",
      "event": "recovery_failed",
      "to": "failed",
      "guards": [],
      "recovery_mode": "force_failed"
    }
  ],
  "guard_definitions": {
    "workspace_present": {
      "description": "A workspace identity exists and is bound to the transaction."
    },
    "workspace_trusted": {
      "description": "Workspace trust level satisfies minimum trust for the transaction kind."
    },
    "workspace_healthy": {
      "description": "Workspace health satisfies minimum health for the transaction kind."
    },
    "target_identity_resolved": {
      "description": "Target scope and identity are explicit and canonical."
    },
    "policy_bound": {
      "description": "Required policy surfaces are version-bound to the transaction context."
    },
    "verify_passed": {
      "description": "Fresh authoritative verification passed with blocking checks satisfied."
    },
    "verify_fresh": {
      "description": "Verification evidence remains within freshness limits for this transaction kind."
    },
    "replay_passed": {
      "description": "Replay or lineage evidence passed."
    },
    "replay_deterministic": {
      "description": "Replay determinism state is deterministic where required."
    },
    "environment_compatible": {
      "description": "Recorded and current environments are exact or compatible per policy."
    },
    "confirmation_present": {
      "description": "Explicit confirmation exists for the current target and scope."
    },
    "confirmation_fresh": {
      "description": "Confirmation is fresh and has not been invalidated by scope drift."
    },
    "scheduler_admitted": {
      "description": "Governed scheduler accepted the transaction for execution."
    },
    "ledger_available": {
      "description": "Ledger sink is available and authoritative for persistence."
    },
    "rollback_target_available": {
      "description": "Rollback target exists and is explicit for the current transaction."
    },
    "secrets_clean": {
      "description": "No secret policy violations block the transaction."
    },
    "release_attested": {
      "description": "Release provenance, signing, and attestation requirements are satisfied."
    }
  },
  "recovery_rules": {
    "persist_required_before_terminal_success": true,
    "persist_required_before_terminal_rollback": true,
    "reconstruct_from": [
      "ledger",
      "artifact_manifest",
      "transaction_log",
      "verify_artifact",
      "replay_artifact"
    ],
    "deny_resume_if": [
      "persisted_state_missing",
      "ledger_conflict_detected",
      "workspace_identity_changed_for_non_resumable_kind"
    ],
    "force_failed_if": [
      "state_reconstruction_incomplete",
      "required_artifacts_missing",
      "required_guards_cannot_be_revalidated"
    ],
    "force_rollback_if": [
      "patch_apply_crashed_after_partial_mutation",
      "release_promotion_crashed_after_partial_publish"
    ]
  },
  "audit_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "transaction_id",
      "transaction_kind",
      "from_state",
      "to_state",
      "event",
      "evaluated_at"
    ],
    "properties": {
      "transaction_id": {
        "type": "string",
        "minLength": 1
      },
      "transaction_kind": {
        "type": "string",
        "enum": [
          "workspace_open",
          "verify_run",
          "replay_run",
          "patch_review",
          "patch_apply",
          "rollback",
          "command_run",
          "settings_update",
          "trust_update",
          "release_promotion"
        ]
      },
      "from_state": {
        "type": "string",
        "enum": [
          "created",
          "admitted",
          "hydrating_context",
          "awaiting_trust",
          "awaiting_input",
          "awaiting_verify",
          "awaiting_replay",
          "awaiting_confirmation",
          "ready",
          "scheduled",
          "running",
          "persisting_artifacts",
          "persisting_ledger",
          "completed",
          "completed_with_warnings",
          "denied",
          "blocked",
          "failed",
          "timed_out",
          "cancelled",
          "rollback_pending",
          "rolled_back",
          "recovery_pending",
          "recovering",
          "superseded"
        ]
      },
      "to_state": {
        "type": "string",
        "enum": [
          "created",
          "admitted",
          "hydrating_context",
          "awaiting_trust",
          "awaiting_input",
          "awaiting_verify",
          "awaiting_replay",
          "awaiting_confirmation",
          "ready",
          "scheduled",
          "running",
          "persisting_artifacts",
          "persisting_ledger",
          "completed",
          "completed_with_warnings",
          "denied",
          "blocked",
          "failed",
          "timed_out",
          "cancelled",
          "rollback_pending",
          "rolled_back",
          "recovery_pending",
          "recovering",
          "superseded"
        ]
      },
      "event": {
        "type": "string",
        "enum": [
          "create",
          "admit",
          "hydrate_context_ok",
          "hydrate_context_failed",
          "trust_granted",
          "trust_denied",
          "input_bound",
          "verify_started",
          "verify_passed",
          "verify_warned",
          "verify_failed",
          "verify_stale",
          "replay_started",
          "replay_passed",
          "replay_failed",
          "replay_non_deterministic",
          "confirmation_received",
          "confirmation_expired",
          "scheduler_admitted",
          "run_started",
          "run_progressed",
          "run_failed",
          "run_timed_out",
          "artifacts_persisted",
          "ledger_persisted",
          "complete_ok",
          "complete_warn",
          "deny",
          "block",
          "cancel",
          "supersede",
          "request_rollback",
          "rollback_completed",
          "crash_detected",
          "resume",
          "recovery_failed"
        ]
      },
      "guards_checked": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "decision": {
        "type": "string",
        "enum": [
          "allow",
          "allow_with_warning",
          "deny"
        ]
      },
      "evaluated_at": {
        "$ref": "#/$defs/timestamp"
      }
    }
  }
}
