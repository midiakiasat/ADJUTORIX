{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "adjutorix.rpc-capabilities",
  "version": 1,
  "title": "ADJUTORIX RPC Capabilities Contract",
  "description": "Canonical machine-readable contract describing governed RPC methods, capability classes, authority constraints, input/output schemas, policy bindings, and attestation semantics for the ADJUTORIX runtime.",
  "meta": {
    "owners": [
      "core-governance",
      "agent-runtime",
      "cli-runtime",
      "app-runtime"
    ],
    "status": "active",
    "default_decision": "deny",
    "invariants": [
      "No callable mutation surface without explicit policy binding.",
      "No authoritative readiness or success claim without verify/replay evidence where required.",
      "No hidden capability escalation by transport, client, or caller identity alone.",
      "No method may return unredacted secrets or credential material.",
      "Every consequential method must emit auditable evidence fields."
    ]
  },
  "enums": {
    "authority_surface": [
      "governed_agent_rpc"
    ],
    "trust_level": [
      "none",
      "observed",
      "tentative",
      "trusted",
      "elevated",
      "quarantined",
      "revoked"
    ],
    "workspace_health": [
      "healthy",
      "degraded",
      "unhealthy",
      "blocked"
    ],
    "verify_status": [
      "pending",
      "running",
      "passed",
      "warning",
      "failed",
      "blocked",
      "stale",
      "superseded"
    ],
    "apply_readiness": [
      "ready",
      "caution",
      "blocked",
      "unknown"
    ],
    "replay_status": [
      "pending",
      "running",
      "passed",
      "warning",
      "failed",
      "blocked",
      "stale",
      "superseded"
    ],
    "determinism_state": [
      "deterministic",
      "non_deterministic",
      "unknown"
    ],
    "environment_match": [
      "exact",
      "compatible",
      "drifted",
      "unknown"
    ],
    "capability_class": [
      "identity",
      "health",
      "workspace",
      "verify",
      "replay",
      "ledger",
      "patch",
      "command",
      "diagnostics",
      "settings",
      "governance",
      "release"
    ],
    "mutation_class": [
      "none",
      "local_ephemeral",
      "settings_persist",
      "workspace_write",
      "patch_apply",
      "rollback",
      "shell_execution",
      "artifact_export",
      "trust_elevation"
    ],
    "confirmation_mode": [
      "none",
      "recommended",
      "required_consequential",
      "required_destructive"
    ],
    "idempotency": [
      "idempotent",
      "conditionally_idempotent",
      "non_idempotent"
    ],
    "transport": [
      "jsonrpc-2.0"
    ],
    "error_code": [
      "E_PARSE",
      "E_INVALID_PARAMS",
      "E_UNAUTHORIZED",
      "E_FORBIDDEN",
      "E_TRUST_REQUIRED",
      "E_WORKSPACE_REQUIRED",
      "E_WORKSPACE_UNHEALTHY",
      "E_VERIFY_REQUIRED",
      "E_VERIFY_STALE",
      "E_REPLAY_REQUIRED",
      "E_REPLAY_BLOCKED",
      "E_CONFIRMATION_REQUIRED",
      "E_POLICY_DENIED",
      "E_TARGET_NOT_FOUND",
      "E_CONFLICT",
      "E_TIMEOUT",
      "E_INTERNAL"
    ]
  },
  "shared": {
    "required_request_meta": [
      "request_id",
      "client",
      "sent_at"
    ],
    "required_audit_fields": [
      "method",
      "capability_class",
      "authority_surface",
      "decision",
      "evaluated_at"
    ],
    "required_consequential_audit_fields": [
      "workspace_id",
      "trust_level",
      "workspace_health",
      "policy_bindings",
      "environment_fingerprint"
    ],
    "policy_bindings": {
      "workspace": "adjutorix.workspace-policy",
      "mutation": "adjutorix.mutation-policy",
      "command": "adjutorix.command-policy",
      "verify": "adjutorix.verify-policy",
      "trust": "adjutorix.trust-policy",
      "targets": "adjutorix.governed-targets",
      "secrets": "adjutorix.secrets-policy",
      "release": "adjutorix.release-policy"
    }
  },
  "schemas": {
    "uuid_like": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "root_path",
        "canonical_root_path",
        "trust_level",
        "workspace_health"
      ],
      "properties": {
        "workspace_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "root_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "canonical_root_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trust_level": {
          "$ref": "#/$defs/trust_level"
        },
        "workspace_health": {
          "$ref": "#/$defs/workspace_health"
        },
        "workspace_kind": {
          "type": "string"
        },
        "filesystem_fingerprint": {
          "type": "string"
        }
      }
    },
    "environment_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recorded_environment_fingerprint",
        "current_environment_fingerprint",
        "environment_match"
      ],
      "properties": {
        "recorded_environment_fingerprint": {
          "type": "string"
        },
        "current_environment_fingerprint": {
          "type": "string"
        },
        "environment_match": {
          "$ref": "#/$defs/environment_match"
        },
        "toolchain": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "verify_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verify_id",
        "verify_status",
        "apply_readiness"
      ],
      "properties": {
        "verify_id": {
          "type": "string"
        },
        "verify_status": {
          "$ref": "#/$defs/verify_status"
        },
        "apply_readiness": {
          "$ref": "#/$defs/apply_readiness"
        },
        "fresh": {
          "type": "boolean"
        },
        "blocking_failures": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "replay_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_status",
        "determinism_state",
        "replayable_lineage"
      ],
      "properties": {
        "replay_status": {
          "$ref": "#/$defs/replay_status"
        },
        "determinism_state": {
          "$ref": "#/$defs/determinism_state"
        },
        "replayable_lineage": {
          "type": "boolean"
        },
        "ledger_id": {
          "type": "string"
        },
        "selected_seq": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "policy_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "policy_bindings",
        "evaluated_at"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "allow_with_warning",
            "deny"
          ]
        },
        "policy_bindings": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evaluated_at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "audit_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "capability_class",
        "authority_surface",
        "decision",
        "evaluated_at"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "capability_class": {
          "$ref": "#/$defs/capability_class"
        },
        "authority_surface": {
          "$ref": "#/$defs/authority_surface"
        },
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "allow_with_warning",
            "deny"
          ]
        },
        "workspace_id": {
          "type": "string"
        },
        "trust_level": {
          "$ref": "#/$defs/trust_level"
        },
        "workspace_health": {
          "$ref": "#/$defs/workspace_health"
        },
        "environment_fingerprint": {
          "type": "string"
        },
        "evaluated_at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "jsonrpc_error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/error_code"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      }
    }
  },
  "methods": {
    "system.ping": {
      "title": "System Ping",
      "capability_class": "identity",
      "description": "Liveness and compatibility probe for the governed RPC endpoint.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "none",
      "confirmation_mode": "none",
      "idempotency": "idempotent",
      "trust_requirements": {
        "minimum_trust_level": "none",
        "workspace_required": false,
        "verify_required": false,
        "replay_required": false
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ok",
          "server_time",
          "rpc_contract_id",
          "rpc_contract_version",
          "audit"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "server_time": {
            "$ref": "#/$defs/timestamp"
          },
          "rpc_contract_id": {
            "const": "adjutorix.rpc-capabilities"
          },
          "rpc_contract_version": {
            "const": 1
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_INTERNAL"
      ]
    },
    "system.capabilities": {
      "title": "Enumerate Capabilities",
      "capability_class": "identity",
      "description": "Return the active method/capability registry visible to the client, including policy and authority bindings.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "none",
      "confirmation_mode": "none",
      "idempotency": "idempotent",
      "trust_requirements": {
        "minimum_trust_level": "observed",
        "workspace_required": false,
        "verify_required": false,
        "replay_required": false
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "include_methods": {
            "type": "boolean",
            "default": true
          },
          "include_policies": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contract_id",
          "version",
          "methods",
          "audit"
        ],
        "properties": {
          "contract_id": {
            "const": "adjutorix.rpc-capabilities"
          },
          "version": {
            "const": 1
          },
          "methods": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "policy_bindings": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_UNAUTHORIZED",
        "E_INTERNAL"
      ]
    },
    "workspace.open": {
      "title": "Open Workspace",
      "capability_class": "workspace",
      "description": "Resolve, classify, and open a candidate workspace root under workspace policy.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "local_ephemeral",
      "confirmation_mode": "recommended",
      "idempotency": "conditionally_idempotent",
      "trust_requirements": {
        "minimum_trust_level": "observed",
        "workspace_required": false,
        "verify_required": false,
        "replay_required": false,
        "policy_bindings": [
          "adjutorix.workspace-policy",
          "adjutorix.trust-policy"
        ]
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "root_path"
        ],
        "properties": {
          "root_path": {
            "type": "string",
            "minLength": 1
          },
          "restore_session": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workspace",
          "policy",
          "audit"
        ],
        "properties": {
          "workspace": {
            "$ref": "#/$defs/workspace_identity"
          },
          "restored_session": {
            "type": "boolean"
          },
          "policy": {
            "$ref": "#/$defs/policy_decision"
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_INVALID_PARAMS",
        "E_POLICY_DENIED",
        "E_TARGET_NOT_FOUND",
        "E_INTERNAL"
      ]
    },
    "workspace.health": {
      "title": "Workspace Health",
      "capability_class": "health",
      "description": "Return current workspace identity, trust, health, ignore, and watcher state.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "none",
      "confirmation_mode": "none",
      "idempotency": "idempotent",
      "trust_requirements": {
        "minimum_trust_level": "observed",
        "workspace_required": true,
        "verify_required": false,
        "replay_required": false
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workspace_id"
        ],
        "properties": {
          "workspace_id": {
            "type": "string"
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workspace",
          "watch_mode",
          "policy",
          "audit"
        ],
        "properties": {
          "workspace": {
            "$ref": "#/$defs/workspace_identity"
          },
          "watch_mode": {
            "type": "string"
          },
          "ignore_profile_id": {
            "type": "string"
          },
          "policy": {
            "$ref": "#/$defs/policy_decision"
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_WORKSPACE_REQUIRED",
        "E_TARGET_NOT_FOUND",
        "E_INTERNAL"
      ]
    },
    "verify.run": {
      "title": "Run Verification",
      "capability_class": "verify",
      "description": "Run a governed verification aggregation over an explicit target scope and emit authoritative verify evidence.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "local_ephemeral",
      "confirmation_mode": "recommended",
      "idempotency": "conditionally_idempotent",
      "trust_requirements": {
        "minimum_trust_level": "trusted",
        "workspace_required": true,
        "verify_required": false,
        "replay_required": false,
        "minimum_workspace_health": "healthy",
        "policy_bindings": [
          "adjutorix.verify-policy",
          "adjutorix.workspace-policy",
          "adjutorix.trust-policy"
        ]
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workspace_id",
          "verify_kind",
          "scope_kind",
          "target_identity"
        ],
        "properties": {
          "workspace_id": {
            "type": "string"
          },
          "verify_kind": {
            "type": "string",
            "enum": [
              "informational",
              "mutation_guard",
              "release_guard"
            ]
          },
          "scope_kind": {
            "type": "string",
            "enum": [
              "patch",
              "workspace",
              "ledger_selection",
              "release_candidate",
              "targeted_files",
              "command_result"
            ]
          },
          "target_identity": {
            "type": "object"
          },
          "force_refresh": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verify",
          "environment",
          "policy",
          "audit"
        ],
        "properties": {
          "verify": {
            "$ref": "#/$defs/verify_summary"
          },
          "environment": {
            "$ref": "#/$defs/environment_summary"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "policy": {
            "$ref": "#/$defs/policy_decision"
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_INVALID_PARAMS",
        "E_TRUST_REQUIRED",
        "E_WORKSPACE_REQUIRED",
        "E_WORKSPACE_UNHEALTHY",
        "E_POLICY_DENIED",
        "E_INTERNAL"
      ]
    },
    "verify.status": {
      "title": "Verify Status",
      "capability_class": "verify",
      "description": "Return an existing verify result and freshness/relevance state for a verify identifier.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "none",
      "confirmation_mode": "none",
      "idempotency": "idempotent",
      "trust_requirements": {
        "minimum_trust_level": "observed",
        "workspace_required": false,
        "verify_required": false,
        "replay_required": false
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verify_id"
        ],
        "properties": {
          "verify_id": {
            "type": "string"
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verify",
          "environment",
          "audit"
        ],
        "properties": {
          "verify": {
            "$ref": "#/$defs/verify_summary"
          },
          "environment": {
            "$ref": "#/$defs/environment_summary"
          },
          "superseded_by": {
            "type": "string"
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_TARGET_NOT_FOUND",
        "E_INTERNAL"
      ]
    },
    "replay.run": {
      "title": "Run Replay",
      "capability_class": "replay",
      "description": "Run a governed replay or lineage assessment over a ledger selection or workspace scope.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "local_ephemeral",
      "confirmation_mode": "recommended",
      "idempotency": "conditionally_idempotent",
      "trust_requirements": {
        "minimum_trust_level": "trusted",
        "workspace_required": true,
        "verify_required": false,
        "replay_required": false,
        "minimum_workspace_health": "healthy",
        "policy_bindings": [
          "adjutorix.verify-policy",
          "adjutorix.workspace-policy",
          "adjutorix.trust-policy"
        ]
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workspace_id"
        ],
        "properties": {
          "workspace_id": {
            "type": "string"
          },
          "ledger_id": {
            "type": "string"
          },
          "selected_seq": {
            "type": "integer",
            "minimum": 0
          },
          "target_identity": {
            "type": "object"
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "replay",
          "environment",
          "policy",
          "audit"
        ],
        "properties": {
          "replay": {
            "$ref": "#/$defs/replay_summary"
          },
          "environment": {
            "$ref": "#/$defs/environment_summary"
          },
          "policy": {
            "$ref": "#/$defs/policy_decision"
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_TRUST_REQUIRED",
        "E_WORKSPACE_REQUIRED",
        "E_WORKSPACE_UNHEALTHY",
        "E_POLICY_DENIED",
        "E_INTERNAL"
      ]
    },
    "ledger.status": {
      "title": "Ledger Status",
      "capability_class": "ledger",
      "description": "Return current ledger identity, selected sequence, head sequence, and rollback availability.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "none",
      "confirmation_mode": "none",
      "idempotency": "idempotent",
      "trust_requirements": {
        "minimum_trust_level": "observed",
        "workspace_required": true,
        "verify_required": false,
        "replay_required": false
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workspace_id"
        ],
        "properties": {
          "workspace_id": {
            "type": "string"
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ledger_id",
          "selected_seq",
          "head_seq",
          "audit"
        ],
        "properties": {
          "ledger_id": {
            "type": "string"
          },
          "selected_seq": {
            "type": "integer",
            "minimum": 0
          },
          "head_seq": {
            "type": "integer",
            "minimum": 0
          },
          "rollback_target_available": {
            "type": "boolean"
          },
          "audit": {
            "$ref": "#/$defs/audit_envelope"
          }
        }
      },
      "errors": [
        "E_WORKSPACE_REQUIRED",
        "E_TARGET_NOT_FOUND",
        "E_INTERNAL"
      ]
    },
    "patch.preview": {
      "title": "Preview Patch",
      "capability_class": "patch",
      "description": "Materialize a governed preview of a patch or patch set without crossing the apply boundary.",
      "transport": "jsonrpc-2.0",
      "mutation_class": "none",
      "confirmation_mode": "none",
      "idempotency": "idempotent",
      "trust_requirements": {
        "minimum_trust_level": "observed",
        "workspace_required": true,
        "verify_required": false,
        "replay_required": false
      },
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workspace_id",
          "patch_id"
        ],
        "properties": {
          "workspace_id": {
            "type": "string"
          },
          "patch_id": {
            "type": "string"
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "patch_id",
          "changed_files",
          "diff_summary",
          "audit"
        ],
