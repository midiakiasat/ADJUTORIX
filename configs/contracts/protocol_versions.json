        "renderer.bridge.runtime": "1.x",
        "workspace.state.session": "1.x"
      }
    },
    "adjutorix-cli": {
      "requires": {
        "rpc.jsonrpc.adjutorix": "1.x",
        "ledger.format.core": "1.x",
        "verify.format.core": "1.x",
        "replay.format.core": "1.x",
        "cli.protocol.runtime": "1.x",
        "audit.command.format": "1.x"
      }
    },
    "adjutorix-agent": {
      "requires": {
        "rpc.jsonrpc.adjutorix": "1.x",
        "ledger.format.core": "1.x",
        "verify.format.core": "1.x",
        "replay.format.core": "1.x",
        "policy.surface.mutation": "1.x",
        "policy.surface.command": "1.x",
        "policy.surface.verify": "1.x",
        "audit.command.format": "1.x"
      }
    },
    "adjutorix-release-pipeline": {
      "requires": {
        "verify.format.core": "1.x",
        "policy.surface.verify": "1.x",
        "artifact.manifest.release": "1.x",
        "release.metadata.bundle": "1.x"
      }
    }
  },
  "negotiation": {
    "strategy": "highest_mutually_supported_major_within_declared_ranges",
    "deny_if": [
      "no_intersection",
      "required_surface_missing",
      "surface_retired",
      "surface_stability_below_required_level"
    ],
    "stability_requirements": {
      "adjutorix-release-pipeline": "stable",
      "adjutorix-app-main": "stable",
      "adjutorix-cli": "stable",
      "adjutorix-agent": "stable",
      "adjutorix-app-renderer": "stable",
      "adjutorix-app-preload": "stable"
    }
  },
  "drift_guards": {
    "require_contract_drift_guard": true,
    "require_protocol_registry_update_on_breaking_change": true,
    "require_history_entry_on_version_change": true,
    "require_consumer_range_update_when_needed": true
  }
}
