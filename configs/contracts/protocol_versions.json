{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "adjutorix.protocol-versions",
  "version": 1,
  "title": "ADJUTORIX Protocol and Surface Version Registry",
  "description": "Canonical machine-readable registry of versioned protocols, contracts, policy surfaces, artifact formats, and compatibility rules across ADJUTORIX. This file is the single source of truth for cross-component negotiation and drift detection.",
  "status": "active",
  "owners": [
    "core-governance",
    "agent-runtime",
    "app-runtime",
    "cli-runtime",
    "release-engineering"
  ],
  "defaults": {
    "compatibility_decision": "deny",
    "missing_version_behavior": "deny",
    "unknown_surface_behavior": "deny"
  },
  "invariants": [
    "No authoritative cross-surface interaction without explicit version binding.",
    "No compatibility decision may be inferred from semantic similarity alone.",
    "No policy-bearing surface may version independently without being listed here.",
    "Every breaking change must declare minimum and maximum compatible peers.",
    "Every persisted artifact format must map to at least one reader compatibility rule."
  ],
  "enums": {
    "surface_kind": [
      "rpc",
      "preload_api",
      "renderer_bridge",
      "ledger_format",
      "verify_format",
      "replay_format",
      "workspace_state",
      "settings_format",
      "policy_surface",
      "artifact_manifest",
      "release_metadata",
      "cli_protocol",
      "command_audit_format",
      "diagnostics_format"
    ],
    "stability": [
      "experimental",
      "internal",
      "beta",
      "stable",
      "deprecated",
      "retired"
    ],
    "compatibility": [
      "exact",
      "forward_compatible",
      "backward_compatible",
      "conditionally_compatible",
      "incompatible"
    ],
    "change_kind": [
      "patch",
      "minor",
      "major",
      "schema_only",
      "policy_only",
      "format_break"
    ],
    "consumer": [
      "adjutorix-app-main",
      "adjutorix-app-preload",
      "adjutorix-app-renderer",
      "adjutorix-cli",
      "adjutorix-agent",
      "adjutorix-ci",
      "adjutorix-release-pipeline"
    ]
  },
  "global_rules": {
    "version_scheme": "semver",
    "require_semver_strings": true,
    "breaking_change_requires_major_bump": true,
    "deprecated_surfaces_require_replacement_reference": true,
    "retired_surfaces_must_not_be_default": true,
    "policy_surfaces_must_increment_on_rule_meaning_change": true,
    "persisted_formats_must_define_reader_compatibility": true
  },
  "surfaces": [
    {
      "id": "rpc.jsonrpc.adjutorix",
      "kind": "rpc",
      "title": "Governed JSON-RPC Surface",
      "stability": "stable",
      "current_version": "1.0.0",
      "current_protocol_integer": 1,
      "transport": "jsonrpc-2.0",
      "owned_by": "agent-runtime",
      "contract_ref": "configs/contracts/rpc_capabilities.json",
      "default_for": [
        "adjutorix-agent",
        "adjutorix-cli",
        "adjutorix-app-main"
      ],
      "compatibility_rules": {
        "exact_match_required_for": [
          "method_presence",
          "error_code_meanings",
          "audit_envelope_required_fields"
        ],
        "forward_compatible_if": [
          "new_optional_methods_only",
          "new_optional_response_fields_only"
        ],
        "incompatible_if": [
          "required_param_removed",
          "required_response_field_removed",
          "error_code_reused_with_new_meaning",
          "policy_binding_removed"
        ]
      },
      "supported_consumers": {
        "adjutorix-cli": {
          "min": "1.0.0",
          "max": "1.x"
        },
        "adjutorix-app-main": {
          "min": "1.0.0",
          "max": "1.x"
        },
        "adjutorix-ci": {
          "min": "1.0.0",
          "max": "1.x"
        }
      },
      "history": [
        {
          "version": "1.0.0",
          "change_kind": "major",
          "status": "current",
          "notes": "Initial governed RPC contract with explicit policy, trust, verify, replay, and audit bindings."
        }
      ]
    },
