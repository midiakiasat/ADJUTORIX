{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adjutorix://contracts/fs_op.schema.json",
  "title": "FsOp",
  "type": "object",
  "additionalProperties": false,
  "required": ["op", "path"],
  "properties": {
    "op": { "type": "string", "enum": ["write", "delete", "mkdir", "chmod", "rename"] },
    "path": { "type": "string", "minLength": 1 },
    "to": { "type": "string" },
    "content_b64": { "type": "string" },
    "mode": { "type": "integer", "minimum": 0, "maximum": 511 }
  },
  "allOf": [
    {
      "if": { "properties": { "op": { "const": "write" } } },
      "then": { "required": ["content_b64"] }
    },
    {
      "if": { "properties": { "op": { "const": "rename" } } },
      "then": { "required": ["to"] }
    },
    {
      "if": { "properties": { "op": { "const": "chmod" } } },
      "then": { "required": ["mode"] }
    }
  ]
}
