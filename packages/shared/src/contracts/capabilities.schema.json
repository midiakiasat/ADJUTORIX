{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adjutorix://contracts/capabilities.schema.json",
  "title": "Capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "capabilities"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chat": { "type": "boolean" },
        "plan": { "type": "boolean" },
        "patch": { "type": "boolean" },
        "apply": { "type": "boolean" },
        "run": { "type": "boolean" },
        "ledger": { "type": "boolean" },
        "replay": { "type": "boolean" },
        "tools": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["chat", "plan", "patch", "apply", "run", "ledger", "replay", "tools"]
    }
  }
}
