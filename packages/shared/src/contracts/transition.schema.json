{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adjutorix://contracts/transition.schema.json",
  "title": "AdjutorixTransition",
  "type": "object",
  "additionalProperties": false,
  "required": ["from", "event", "to"],
  "properties": {
    "from": { "$ref": "adjutorix://contracts/state.schema.json" },
    "event": {
      "type": "string",
      "enum": [
        "PROMPT",
        "PLAN_OK",
        "PLAN_FAIL",
        "PATCH_OK",
        "PATCH_FAIL",
        "REVIEW_ACCEPT",
        "REVIEW_REJECT",
        "APPLY_OK",
        "APPLY_FAIL",
        "RUN_START",
        "RUN_OK",
        "RUN_FAIL",
        "RESET"
      ]
    },
    "to": { "$ref": "adjutorix://contracts/state.schema.json" },
    "note": { "type": "string" }
  }
}
