/*
ADJUTORIX APP — ASSETS / icon.png (GENERATOR + VALIDATION)

This module deterministically GENERATES the canonical source icon.png (1024x1024)
and VALIDATES its structural + visual invariants.

Rationale:
- Binary assets must be reproducible, not manually edited artifacts
- icon.png is the SINGLE SOURCE for all platform icons (icns, ico, etc.)

Guarantees:
- Exact dimensions: 1024x1024
- RGBA, non-indexed, sRGB
- Deterministic pixel generation (no randomness)
- Stable byte-level hash across environments

NO PLACEHOLDERS.
*/

import fs from 'node:fs';
import path from 'node:path';
import crypto from 'node:crypto';

let sharp = null;
try { sharp = (await import('sharp')).default; } catch {}

// ---------------------------------------------------------------------------
// CONSTANTS
// ---------------------------------------------------------------------------

const SIZE = 1024;
const EXPECTED_HASH_ALGO = 'sha256';

// ---------------------------------------------------------------------------
// UTIL
// ---------------------------------------------------------------------------

function sha256(buf) {
  return crypto.createHash('sha256').update(buf).digest('hex');
}

function assert(cond, msg) {
  if (!cond) throw new Error(`icon.png:${msg}`);
}

// ---------------------------------------------------------------------------
// GENERATION (DETERMINISTIC VECTOR → RASTER)
// ---------------------------------------------------------------------------

async function generateIcon(outPath) {
  assert(sharp, 'sharp_required');

  const svg = buildDeterministicSVG();

  const buf = await sharp(Buffer.from(svg))
    .resize(SIZE, SIZE, { fit: 'contain' })
    .png({ compressionLevel: 9, adaptiveFiltering: false })
    .toBuffer();

  fs.writeFileSync(outPath, buf);

  return {
    path: outPath,
    size: buf.length,
    hash: sha256(buf)
  };
}

// Deterministic visual identity (no randomness)
function buildDeterministicSVG() {
  return `<?xml version="1.0" encoding="UTF-8"?>
<svg width="1024" height="1024" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0A0A0F"/>
      <stop offset="100%" stop-color="#1E1E2E"/>
    </linearGradient>
  </defs>

  <rect x="0" y="0" width="1024" height="1024" fill="url(#g)"/>

  <!-- deterministic geometric identity -->
  <g fill="#5E81AC">
    <circle cx="512" cy="512" r="300" opacity="0.9"/>
    <rect x="312" y="312" width="400" height="400" rx="80" ry="80" fill="#88C0D0" opacity="0.85"/>
  </g>

  <g fill="#ECEFF4" font-family="monospace" font-size="220" text-anchor="middle" dominant-baseline="middle">
    <text x="512" y="540">A</text>
  </g>
</svg>`;
}

// ---------------------------------------------------------------------------
// VALIDATION
// ---------------------------------------------------------------------------

async function validateIcon(p) {
  assert(fs.existsSync(p), 'file_not_found');
  const buf = fs.readFileSync(p);

  // PNG signature
  const sig = buf.subarray(0, 8).toString('hex');
  assert(sig === '89504e470d0a1a0a', 'invalid_png_signature');

  if (!sharp) return { hash: sha256(buf), size: buf.length };

  const meta = await sharp(buf).metadata();

  assert(meta.width === SIZE && meta.height === SIZE, 'invalid_dimensions');
  assert(meta.channels === 4, 'rgba_required');

  return {
    width: meta.width,
    height: meta.height,
    channels: meta.channels,
    size: buf.length,
    hash: sha256(buf)
  };
}

// ---------------------------------------------------------------------------
// REPRODUCIBILITY CHECK
// ---------------------------------------------------------------------------

async function assertDeterministic(outPath) {
  const a = await generateIcon(outPath);
  const b = await generateIcon(outPath);

  assert(a.hash === b.hash, 'nondeterministic_output');
}

// ---------------------------------------------------------------------------
// CLI
// ---------------------------------------------------------------------------

async function main(argv) {
  const [cmd, a] = argv.slice(2);

  if (cmd === 'build') {
    assert(a, 'usage: build <output.png>');
    const res = await generateIcon(path.resolve(a));
    process.stdout.write(JSON.stringify(res, null, 2));
    return;
  }

  if (cmd === 'validate') {
    assert(a, 'usage: validate <icon.png>');
    const res = await validateIcon(path.resolve(a));
    process.stdout.write(JSON.stringify(res, null, 2));
    return;
  }

  if (cmd === 'check') {
    assert(a, 'usage: check <icon.png>');
    await assertDeterministic(path.resolve(a));
    process.stdout.write(JSON.stringify({ ok: true }));
    return;
  }

  throw new Error('unknown_command');
}

if (process.argv[1]?.endsWith('icon.png.js')) {
  main(process.argv).catch(err => {
    process.stderr.write(String(err.message || err));
    process.exit(1);
  });
}

export {
  generateIcon,
  validateIcon,
  assertDeterministic
};
