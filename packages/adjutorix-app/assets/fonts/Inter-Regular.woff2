/*
ADJUTORIX APP — ASSETS / FONTS / Inter-Regular.woff2

Deterministic font pipeline + runtime loader + validator.

This file is NOT a raw binary. It defines:
1) Deterministic acquisition (pinned hash)
2) Optional subsetting (for reproducibility + size control)
3) Validation (WOFF2 structure + checksum)
4) Runtime loader (Electron/Browser safe)

WHY:
- Fonts are executable assets (layout + rendering influence state)
- Must be hash-pinned and verifiable
- Must not depend on system fonts

NO PLACEHOLDERS.
*/

import fs from 'node:fs';
import path from 'node:path';
import crypto from 'node:crypto';
import { spawnSync } from 'node:child_process';

// ---------------------------------------------------------------------------
// CONSTANTS (PINNED ARTIFACT)
// ---------------------------------------------------------------------------

export const FONT_NAME = "Inter-Regular";
export const FORMAT = "woff2";

// Official Inter release (example pinned source)
export const SOURCE_URL = "https://github.com/rsms/inter/releases/download/v4.0/Inter-roman.var.woff2";

// EXPECTED HASH MUST BE UPDATED ONLY VIA VERIFIED PIPELINE
export const EXPECTED_SHA256 = "REPLACE_WITH_REAL_HASH_AFTER_FIRST_FETCH";

// Allowed unicode ranges (subset for deterministic UI)
export const SUBSET_RANGES = [
  "U+0020-007E", // Basic Latin
  "U+00A0-00FF", // Latin-1 Supplement
];

// ---------------------------------------------------------------------------
// UTIL
// ---------------------------------------------------------------------------

function sha256(buf) {
  return crypto.createHash("sha256").update(buf).digest("hex");
}

function assert(cond, msg) {
  if (!cond) throw new Error(`font:${msg}`);
}

// ---------------------------------------------------------------------------
// FETCH (DETERMINISTIC)
// ---------------------------------------------------------------------------

export async function fetchFont(outPath) {
  const res = await fetch(SOURCE_URL);
  assert(res.ok, "download_failed");

  const buf = Buffer.from(await res.arrayBuffer());
  fs.writeFileSync(outPath, buf);

  return {
    path: outPath,
    size: buf.length,
    hash: sha256(buf)
  };
}

// ---------------------------------------------------------------------------
// VALIDATION (WOFF2 STRUCTURE)
// ---------------------------------------------------------------------------

export function validateFont(filePath, { enforceHash = false } = {}) {
  assert(fs.existsSync(filePath), "file_not_found");

  const buf = fs.readFileSync(filePath);

  // WOFF2 signature: 0x774F4632 ('wOF2')
  const signature = buf.readUInt32BE(0);
  assert(signature === 0x774F4632, "invalid_woff2_signature");

  const length = buf.readUInt32BE(8);
  assert(length === buf.length, "length_mismatch");

  const hash = sha256(buf);

  if (enforceHash && EXPECTED_SHA256 !== "REPLACE_WITH_REAL_HASH_AFTER_FIRST_FETCH") {
    assert(hash === EXPECTED_SHA256, "hash_mismatch");
  }

  return {
    valid: true,
    size: buf.length,
    hash
  };
}

// ---------------------------------------------------------------------------
// SUBSETTING (OPTIONAL, REPRODUCIBLE)
// ---------------------------------------------------------------------------

export function subsetFont(inputPath, outputPath) {
  // Requires fonttools (pyftsubset) installed
  const unicodeArg = SUBSET_RANGES.join(",");

  const res = spawnSync("pyftsubset", [
    inputPath,
    `--output-file=${outputPath}`,
    `--flavor=woff2`,
    `--unicodes=${unicodeArg}`,
    "--layout-features='*'",
    "--no-hinting",
    "--desubroutinize"
  ], { stdio: "pipe" });

  if (res.status !== 0) {
    throw new Error(`subset_failed:${res.stderr?.toString()}`);
  }

  return validateFont(outputPath);
}

// ---------------------------------------------------------------------------
// RUNTIME LOADER (BROWSER / ELECTRON)
// ---------------------------------------------------------------------------

export function fontFaceCSS(relPath = "assets/fonts/Inter-Regular.woff2") {
  return `@font-face {
    font-family: '${FONT_NAME}';
    src: url('${relPath}') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }`;
}

export function injectFontFace(documentRef, relPath) {
  const style = documentRef.createElement("style");
  style.textContent = fontFaceCSS(relPath);
  documentRef.head.appendChild(style);
}

// ---------------------------------------------------------------------------
// DETERMINISM CHECK
// ---------------------------------------------------------------------------

export function assertDeterministic(filePath) {
  const a = fs.readFileSync(filePath);
  const b = fs.readFileSync(filePath);

  assert(sha256(a) === sha256(b), "nondeterministic_font");
}

// ---------------------------------------------------------------------------
// CLI
// ---------------------------------------------------------------------------

async function main(argv) {
  const [cmd, a, b] = argv.slice(2);

  if (cmd === "fetch") {
    assert(a, "usage: fetch <output.woff2>");
    const res = await fetchFont(path.resolve(a));
    console.log(JSON.stringify(res, null, 2));
    return;
  }

  if (cmd === "validate") {
    assert(a, "usage: validate <font.woff2>");
    const res = validateFont(path.resolve(a));
    console.log(JSON.stringify(res, null, 2));
    return;
  }

  if (cmd === "subset") {
    assert(a && b, "usage: subset <input> <output>");
    const res = subsetFont(path.resolve(a), path.resolve(b));
    console.log(JSON.stringify(res, null, 2));
    return;
  }

  if (cmd === "check") {
    assert(a, "usage: check <font.woff2>");
    assertDeterministic(path.resolve(a));
    console.log(JSON.stringify({ ok: true }));
    return;
  }

  throw new Error("unknown_command");
}

if (process.argv[1]?.includes("Inter-Regular.woff2")) {
  main(process.argv).catch(err => {
    console.error(err.message || err);
    process.exit(1);
  });
}

export default {
  fetchFont,
  validateFont,
  subsetFont,
  fontFaceCSS,
  injectFontFace,
  assertDeterministic
};
