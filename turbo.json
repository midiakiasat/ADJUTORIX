{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        "out/**",
        ".turbo/**"
      ]
    },
    "check": {
      "dependsOn": [
        "^check"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**",
        "test-results/**"
      ]
    },
    "smoke": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "verify": {
      "dependsOn": [
        "build",
        "test"
      ],
      "outputs": [
        "artifacts/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    }
  }
}
